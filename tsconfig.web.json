{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "composite": true,
    "noEmit": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/src/**/*",
    "src/preload/index.d.ts",
    "src/shared/**/*"
  ]
}
