{
  "name": "speech-tutor",
  "version": "0.1.0",
  "description": "Local speech practice tutor powered by Gemma (via Ollama)",
  "main": "./out/main/index.js",
  "author": "Nikita Pennie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-builder install-app-deps && node scripts/fix-electron-install.cjs",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "release:win": "electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.8",
    "better-sqlite3": "^13.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  },
  "allowScripts": {
    "better-sqlite3@13.0.1": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  },
  "build": {
    "appId": "com.nikitapennie.speech-tutor",
    "productName": "Speech Tutor",
    "files": ["out/**/*", "package.json"],
    "asarUnpack": ["**/*.node"],
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Education"
    },
    "win": {
      "target": ["portable"]
    },
    "publish": {
      "provider": "github",
      "owner": "nikitapn",
      "repo": "speech-tutor"
    }
  }
}
